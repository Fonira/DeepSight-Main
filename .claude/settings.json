{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "WebSearch",
      "WebFetch(*)",
      "Agent(*)",
      "NotebookEdit(*)",
      "mcp__*"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/setup-ssh.sh",
            "timeout": 60,
            "statusMessage": "Configuration SSH Hetzner + GitHub..."
          }
        ]
      }
    ]
  }
}

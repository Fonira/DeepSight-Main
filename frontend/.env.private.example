# ==============================================================================
# Prisme Frontend — Environment « privé / personnel » (stack locale)
# Copier en `.env.local` et adapter. Toute la télémétrie reste vide = OFF.
# ==============================================================================

# --- Backend API (backend local) ---
VITE_API_URL=http://localhost:8000

# --- Télémétrie / tiers : laisser VIDE pour tout désactiver ---
# VITE_SENTRY_DSN=        # vide = pas de Sentry
# VITE_POSTHOG_KEY=       # vide = pas de PostHog
# VITE_CRISP_WEBSITE_ID=  # vide = pas de chat Crisp

# --- OAuth (optionnel en local ; email/mot de passe suffit) ---
# VITE_GOOGLE_CLIENT_ID=
# VITE_APPLE_CLIENT_ID=

# --- Stripe : non utilisé en privé ---
# VITE_STRIPE_PUBLIC_KEY=

# ─── Frontend ───
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.*.local

# ─── Backend ───
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/.env
backend/venv/
backend/.venv/

# ─── Mobile ───
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/web-build/
mobile/*.jks
mobile/*.p8
mobile/*.p12
mobile/*.key
mobile/*.mobileprovision
mobile/*.orig.*

# ─── IDE ───
.idea/
.vscode/
*.swp
*.swo

# ─── OS ───
.DS_Store
Thumbs.db

# ─── Logs ───
*.log
npm-debug.log*

# ─── Cache ───
.cache/
.parcel-cache/
.eslintcache

# ─── Testing ───
coverage/

# ─── Secrets ───
.env
.env.*
!.env.example
!.env.production.example
*.pem
credentials.json
play-store-credentials.json
.secrets/
extension/node_modules/  
extension/node_modules/
monitoring/node_modules/
monitoring/test-results/
monitoring/playwright-report/

deepsight-video/
mobile/nul

# Fichiers temporaires Vite
frontend/vite.config.ts.timestamp-*.mjs

# Claude Code worktrees
.claude/worktrees/

# Fichiers poubelle
**/nul
**/null.txt
.git.tmp/

# Secrets & local config
id_hetzner_b64.txt
.claude/settings.local.json
extension/dist/*.map

# Superpowers brainstorm sessions (mockups locaux, serveurs HTTP éphémères)
.superpowers/

.worktrees/

# ═══════════════════════════════════════════════════════════════════════════════
# DeepSight — Variables d'environnement production (Hetzner VPS)
# Copier en .env.production et remplir les valeurs
# ═══════════════════════════════════════════════════════════════════════════════

# --- Database ---
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Auth ---
JWT_SECRET_KEY=CHANGE_ME_MINIMUM_32_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI ---
MISTRAL_API_KEY=
PERPLEXITY_API_KEY=
GROQ_API_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_ETUDIANT=price_...
STRIPE_PRICE_PRO=price_...

# --- Email ---
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@deepsightsynthesis.com

# --- URLs ---
FRONTEND_URL=https://www.deepsightsynthesis.com
ALLOWED_ORIGINS=https://www.deepsightsynthesis.com,http://localhost:5173,http://localhost:8081

# --- Monitoring ---
SENTRY_DSN=
ENVIRONMENT=production

# --- YouTube (optionnel) ---
SUPADATA_API_KEY=

# --- OpenAI Whisper (optionnel) ---
OPENAI_API_KEY=

# --- S3 Backups (optionnel) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

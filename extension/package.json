{
  "name": "deepsight-extension",
  "version": "2.0.0",
  "description": "DeepSight - AI Video Analysis Chrome Extension",
  "private": true,
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build:chrome": "webpack --mode production --env target=chrome",
    "build:firefox": "webpack --mode production --env target=firefox",
    "build:safari": "webpack --mode production --env target=safari",
    "build:all": "npm run build:chrome && npm run build:firefox && npm run build:safari",
    "e2e": "playwright test -c e2e/playwright.config.ts",
    "e2e:headful": "playwright test -c e2e/playwright.config.ts --headed"
  },
  "devDependencies": {
    "@playwright/test": "1.48",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.287",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@types/webextension-polyfill": "^0.12.5",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "mini-css-extract-plugin": "^2.9.2",
    "raw-loader": "^4.0.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@elevenlabs/client": "^0.15.2",
    "preact": "^10.29.1",
    "webextension-polyfill": "^0.12.0"
  }
}

{
  "manifest_version": 3,
  "name": "DeepSight - AI Video Analysis",
  "version": "2.0.0",
  "description": "Analyze YouTube & TikTok videos with AI. Fact-checked summaries, contextual chat, flashcards. Powered by European AI (Mistral).",
  "author": "DeepSight",
  "homepage_url": "https://www.deepsightsynthesis.com",

  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "alarms",
    "identity",
    "clipboardWrite",
    "sidePanel"
  ],

  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://www.tiktok.com/*",
    "https://tiktok.com/*",
    "https://vm.tiktok.com/*",
    "https://m.tiktok.com/*",
    "https://www.deepsightsynthesis.com/*",
    "https://api.deepsightsynthesis.com/*",
    "https://api.elevenlabs.io/*",
    "wss://api.elevenlabs.io/*",
    "https://*.elevenlabs.io/*",
    "wss://*.elevenlabs.io/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://www.tiktok.com/*",
        "https://tiktok.com/*",
        "https://vm.tiktok.com/*",
        "https://m.tiktok.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.deepsightsynthesis.com/*"],
      "js": ["authSync.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://www.deepsightsynthesis.com/*"],
      "js": ["authSyncMain.js"],
      "run_at": "document_end",
      "world": "MAIN"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "DeepSight"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Open DeepSight popup"
    }
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://api.deepsightsynthesis.com https://api.elevenlabs.io wss://api.elevenlabs.io https://*.elevenlabs.io wss://*.elevenlabs.io"
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "assets/*",
        "platforms/*",
        "widget.css",
        "content.css",
        "tokens.css"
      ],
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://www.tiktok.com/*",
        "https://tiktok.com/*",
        "https://vm.tiktok.com/*",
        "https://m.tiktok.com/*"
      ]
    }
  ]
}

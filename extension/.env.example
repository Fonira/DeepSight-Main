# Build-time env vars for the Chrome extension (read by webpack DefinePlugin).
# Copy to `.env` and source it before `npm run build` (or set in CI). Without
# these, posthog-js init becomes a no-op (build still works, no tracking).

# PostHog public project key (safe to commit, but kept in env for parity with
# frontend & to disable analytics in dev by leaving unset).
POSTHOG_KEY=phc_wckMZ2qV1QVvmL7zC7K4kHgKIfFHtUeQINcsaIT4ttc

# PostHog API host (EU residence — RGPD).
POSTHOG_HOST=https://eu.i.posthog.com

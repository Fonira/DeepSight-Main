# ═══════════════════════════════════════════════════════════════════════════
# Prisme — Backend env « privé / personnel » (stack locale, mono-utilisateur)
# ═══════════════════════════════════════════════════════════════════════════
# Copier en `.env.private` (gitignoré) et remplir les clés.
# Démarrage : cd backend/src && uvicorn main:app --reload --port 8000
#   (charger ce fichier au préalable, ex. `export $(grep -v '^#' ../.env.private | xargs)`)
#
# Objectif : usage privé, données publiques uniquement, zéro télémétrie.
# Seuls maximeleparc3@gmail.com + maxime@deepsightsynthesis.com peuvent se connecter
# (allowlist codée dans core/config.py — PRIVATE_MODE_ALLOWED_EMAILS).

# ─── Coeur ───
ENV=development
PORT=8000
# Mode privé : bloque tout compte hors allowlist (403). Actif aussi par défaut en prod.
PRIVATE_MODE=true
# Données publiques only : coupe TOUT scraping (Invidious, Piped, yt-dlp, audio STT,
# discovery yt-dlp, scraping commentaires YT/TikTok, Google Scholar/Decodo).
# Ne laisse que Supadata + APIs officielles (Mistral, arXiv/Crossref/OpenAlex, Tournesol).
PUBLIC_DATA_ONLY=true

# ─── Base de données (SQLite local, zéro install) ───
DATABASE_URL=sqlite+aiosqlite:///./prisme_private.db

# ─── Auth ───
# Générer : python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME_32_chars_minimum

# ─── IA (requis pour l'analyse) ───
MISTRAL_API_KEY=
# Force le web search via l'Agent Mistral officiel (pas de fallback Brave/Perplexity)
MISTRAL_AGENT_PRIMARY=true

# ─── Transcripts (source publique payante — REQUISE en PUBLIC_DATA_ONLY) ───
SUPADATA_API_KEY=

# ─── Scraping explicitement coupé (défense en profondeur, en plus de PUBLIC_DATA_ONLY) ───
DECODO_SCRAPING_DISABLED=true
YOUTUBE_PROXY=

# ─── Télémétrie / tiers : tout OFF (laisser vide) ───
POSTHOG_API_KEY=
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET_NAME=
STRIPE_ENABLED=false
EMAIL_ENABLED=false

# ─── CORS (front local + Expo) ───
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081

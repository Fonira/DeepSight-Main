### 3. GESTION D'ERREURS

```typescript
// Pattern obligatoire pour toutes les requêtes API
try {
  const result = await apiCall();
  return result;
} catch (error) {
  if (error instanceof ApiError) {
    if (error.status === 401) {
      // Token expiré - refresh automatique dans api.ts
    } else if (error.status === 403 && error.code === 'EMAIL_NOT_VERIFIED') {
      navigation.navigate('VerifyEmail');
    } else if (error.status === 429) {
      Alert.alert('Limite atteinte', 'Réessayez dans quelques minutes');
    } else if (error.status === 503) {
      // Service indisponible - retry avec backoff
    }
  }
  throw error;
}
```

